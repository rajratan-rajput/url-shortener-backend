# Development: leave empty to use Vite proxy (/api and /qr -> localhost:5000)
# VITE_API_URL=

# Production (required at build time on Vercel/Render):
# Must include /api suffix — axios calls paths like /auth/login, /url/create
VITE_API_URL=https://your-api.onrender.com/api

# Optional: if QR images load from API host directly, no extra config needed.
# QR URLs are returned as https://your-api.onrender.com/qr/{code}.png
