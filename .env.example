# =============================================================================
# BACKEND (Render / Docker) — required in production
# =============================================================================
NODE_ENV=production
PORT=5000

# Public HTTPS URL of your API (used in short links & QR codes)
# Example: https://url-shortener-api.onrender.com
BASE_URL=https://your-api.onrender.com

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/urlshortener

# Upstash Redis (use rediss:// for TLS)
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# JWT (min 32 characters in production)
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Comma-separated frontend origins (required in production)
# Example: https://your-app.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app

# Required on Render / behind reverse proxy
TRUST_PROXY=1

# Rate limiting (requests per IP per minute)
RATE_LIMIT_MAX=100
SHORTEN_RATE_LIMIT_MAX=30

# Optional
ENABLE_SWAGGER=false
JSON_BODY_LIMIT=32kb

# =============================================================================
# FRONTEND (Vercel / Render static) — set at BUILD time
# =============================================================================
# VITE_API_URL=https://your-api.onrender.com/api

# =============================================================================
# Docker Compose only (not needed for Render + Atlas + Upstash)
# =============================================================================
# APP_PORT=5000
# MONGO_ROOT_USERNAME=admin
# MONGO_ROOT_PASSWORD=change-this-strong-password
# MONGO_DATABASE=urlshortener
# REDIS_PASSWORD=change-this-strong-password
